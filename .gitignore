# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual env
.venv/
venv/

# Data / model artifacts (large or generated; never commit).
# Anchored with a leading slash so these match ONLY the repo-root dirs — an
# unanchored "data/" would also ignore the src/viral_annotation/data package.
/data/*
!/data/.gitkeep
# Cached bacterial UniProt records (gzipped, ~73MB) — committed so training
# doesn't have to re-fetch from UniProt. gunzip once before use.
!/data/bacterial_reviewed.jsonl.gz
/models/
# Generated run outputs (threat profiles, etc.) — regenerable, can be large.
/results/
# Kaggle GPU run outputs (logs + repo snapshot) — regenerable, large.
/kaggle_output/
*.obo
*.fasta
*.fa
*.gaf
*.gpad
*.pt
*.ckpt
*.npy
*.npz
embeddings_cache/

# OS / editor
.DS_Store
*.swp
